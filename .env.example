ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# FastAPI
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# Dash
DASH_HOST=0.0.0.0
DASH_PORT=8050
DASH_DEBUG=True

# Database
DATABASE_URL=sqlite:///./database.db

# Network Monitoring
MONITOR_INTERVAL=5
INTERFACE_NAME=eth0

# Logging
LOG_LEVEL=INFO
